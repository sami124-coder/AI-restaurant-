PORT=4000
JWT_SECRET=replace-this-in-production
DATABASE_PATH=./data/restaurant.db
CLIENT_ORIGIN=http://localhost:5173

# Optional: enable backend-only OpenAI Responses API mode.
# Leave OPENAI_API_KEY empty to use the deterministic built-in assistant.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REASONING_EFFORT=
OPENAI_TEXT_VERBOSITY=
OPENAI_MAX_OUTPUT_TOKENS=1600
